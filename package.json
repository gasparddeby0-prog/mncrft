{
  "name": "voxelcraft",
  "version": "0.1.0",
  "description": "An original, runnable voxel game engine inspired by Minecraft Java Edition. Built from scratch in TypeScript + Three.js with multithreaded procedural world generation.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "smoke": "esbuild scripts/smoke.ts --bundle --platform=node --format=esm --outfile=scripts/smoke.mjs && node scripts/smoke.mjs"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/three": "^0.160.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
